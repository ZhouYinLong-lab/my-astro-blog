---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

const allPosts = await getCollection(
  "blog",
  ({ data }: CollectionEntry<"blog">) => {
    return import.meta.env.PROD ? !data.draft : true;
  },
);
const articleCount = allPosts.length;

let lastUpdateStr = "刚刚";
if (articleCount > 0) {
  const sortedPosts = allPosts.sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  const latestDate = new Date(sortedPosts[0].data.pubDate);
  const today = new Date();
  const diffTime = Math.abs(today.getTime() - latestDate.getTime());
  const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
  lastUpdateStr = diffDays === 0 ? "今天" : `${diffDays} 天前`;
}

const pathname = decodeURI(Astro.url.pathname);
const isHomePage = pathname === "/" || pathname === "/index.html";
const isBlogPage = pathname === "/blog" || pathname === "/blog/";
const isAboutPage = pathname.includes("/about");
const isFriendsPage = pathname.includes("/friends") || pathname.includes("/links");
const shouldShow = isHomePage || isBlogPage || isAboutPage || isFriendsPage;
---

{shouldShow && (
  <div class="card bg-base-100 shadow-sm border border-base-200 p-5 mt-4">
    <h2 class="text-lg font-bold mb-4 flex items-center gap-2 text-base-content">
      <Icon name="lucide:line-chart" class="w-5 h-5 text-primary" />
      <span>网站信息</span>
    </h2>

    <div class="flex flex-col gap-3 text-sm">
      <div class="flex justify-between items-center">
        <span class="text-base-content/80">文章数目</span>
        <span class="font-mono text-base-content font-bold">{articleCount}</span>
      </div>

      <div class="flex justify-between items-center">
        <span class="text-base-content/80">本站访客数</span>
        <span class="font-mono text-base-content" id="site-uv">--</span>
      </div>

      <div class="flex justify-between items-center">
        <span class="text-base-content/80">本站总浏览量</span>
        <span class="font-mono text-base-content" id="site-pv">--</span>
      </div>

      <div class="flex justify-between items-center">
        <span class="text-base-content/80">最后更新</span>
        <span class="font-mono text-base-content">{lastUpdateStr}</span>
      </div>
    </div>
  </div>
)}

<script>
  // Supabase 自建计数器 — 配好 .env 的 PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY 后自动生效
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  if (supabaseUrl && supabaseKey) {
    const supabase = createClient(supabaseUrl, supabaseKey);

      async function trackAndShow() {
        const uvEl = document.getElementById('site-uv');
        const pvEl = document.getElementById('site-pv');

        // PV: 每次访问 +1
        try {
          const { data: pv } = await supabase.rpc('increment_site_pv');
          if (pvEl) pvEl.textContent = pv ?? '--';
        } catch {
          if (pvEl) pvEl.textContent = '--';
        }

        // UV: 检查今日是否已计数 (localStorage 去重)
        const today = new Date().toISOString().slice(0, 10);
        const uvKey = 'uv_' + today;
        if (!localStorage.getItem(uvKey)) {
          localStorage.setItem(uvKey, '1');
          try {
            const { data: uv } = await supabase.rpc('increment_site_uv');
            if (uvEl) uvEl.textContent = uv ?? '--';
          } catch {
            if (uvEl) uvEl.textContent = '--';
          }
        } else {
          // 今日已计数，只读取
          try {
            const { data: uv } = await supabase.rpc('get_site_uv');
            if (uvEl) uvEl.textContent = uv ?? '--';
          } catch {
            if (uvEl) uvEl.textContent = '--';
          }
        }
      }

    document.addEventListener('astro:page-load', trackAndShow);
    trackAndShow();
  }
</script>
