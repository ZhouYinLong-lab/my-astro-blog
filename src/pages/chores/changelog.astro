---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MainCard from "@/components/MainCard.astro";
import { Icon } from "astro-icon/components";

// ⚠️ 将这里的 owner 和 repo 替换为你的真实 GitHub 用户名和仓库名！
const GITHUB_OWNER = "你的GitHub用户名"; 
const GITHUB_REPO = "你的博客仓库名";

// Astro 会在打包时执行这段拉取，生成静态网页，用户毫无感知卡顿
let commits = [];
try {
  const response = await fetch(`https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/commits?per_page=15`);
  if (response.ok) {
    commits = await response.json();
  }
} catch (error) {
  console.error("无法拉取 GitHub 日志", error);
}
---

<BaseLayout title="更新日志">
  <MainCard title="建站日志" description="见证「寒柳别苑」从零到一的每一次版本迭代。">
    <div class="relative border-l-2 border-primary/30 ml-4 md:ml-6 py-4 space-y-8">
      
      {commits.map((commit: any) => (
        <div class="relative pl-6 md:pl-8">
          <div class="absolute -left-[9px] top-1 w-4 h-4 rounded-full bg-base-100 border-2 border-primary"></div>
          
          <div class="flex flex-col gap-1">
            <span class="text-sm font-mono text-base-content/60">
              {new Date(commit.commit.author.date).toLocaleString('zh-CN', { hour12: false })}
            </span>
            <div class="card bg-base-200/50 p-4 border border-base-300">
              <h3 class="text-base font-medium flex items-center gap-2">
                <Icon name="lucide:git-commit" class="w-4 h-4 text-primary" />
                {commit.commit.message.split('\n')[0]} {/* 提取首行作为标题 */}
              </h3>
              <a href={commit.html_url} target="_blank" class="text-xs text-primary/70 hover:underline mt-2 flex items-center gap-1 w-fit">
                查看哈希: {commit.sha.substring(0, 7)}
              </a>
            </div>
          </div>
        </div>
      ))}
      
      {commits.length === 0 && (
        <div class="pl-6 text-base-content/50 italic">暂无日志数据，或拉取失败。</div>
      )}
      
    </div>
  </MainCard>
</BaseLayout>