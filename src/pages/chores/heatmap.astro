---
import { type CollectionEntry, getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

// 1. 获取所有文章
const allPosts = await getCollection(
  "blog",
  ({ data }: CollectionEntry<"blog">) => {
    return import.meta.env.PROD ? !data.draft : true;
  },
);

// 2. 聚合日期数据
const dateCountMap: Record<string, number> = {};
allPosts.forEach((post: CollectionEntry<"blog">) => {
  const date = new Date(post.data.pubDate);
  const dateStr = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}-${String(date.getDate()).padStart(2, "0")}`;
  dateCountMap[dateStr] = (dateCountMap[dateStr] || 0) + 1;
});

// 3. 演算近 365 天的赛博时间线
const today = new Date();
const ONE_DAY = 24 * 60 * 60 * 1000;
const startDate = new Date(today.getTime() - 364 * ONE_DAY);
const startDayOfWeek = startDate.getDay(); // 获取起点是周几

const days = [];
// 填充首周的空白矩阵
for (let i = 0; i < startDayOfWeek; i++) {
  days.push({ dateStr: "", count: -1 });
}
// 生成过去一年的矩阵
for (let i = 0; i <= 364; i++) {
  const d = new Date(startDate.getTime() + i * ONE_DAY);
  const dateStr = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
  days.push({ dateStr, count: dateCountMap[dateStr] || 0 });
}

// 4. 将时间轴折叠为 7x52 的网格周列
const weeks: any[] = [];
let currentWeek: any[] = [];
days.forEach((day) => {
  currentWeek.push(day);
  if (currentWeek.length === 7) {
    weeks.push(currentWeek);
    currentWeek = [];
  }
});
if (currentWeek.length > 0) weeks.push(currentWeek);

// 计算活跃度等级
function getLevel(count: number) {
  if (count === 0) return 0;
  if (count === 1) return 1;
  if (count === 2) return 2;
  return 3;
}
---

<BaseLayout title="赛博足迹 - 热力图">
  <MainCard title="赛博足迹" description="记录在数字世界里每一次的思想脉动与敲击。">
    
    <div class="card bg-base-100/40 backdrop-blur-xl border border-base-200/60 shadow-xl p-8 mt-6">
      
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
        <h3 class="text-xl font-bold flex items-center gap-3">
          <Icon name="lucide:activity" class="w-6 h-6 text-primary animate-pulse" />
          <span class="tracking-widest">思想脉动矩阵</span>
        </h3>
        <div class="text-xs font-mono bg-base-200/80 px-4 py-1.5 rounded-full text-base-content/80 border border-base-300">
          Last 365 Days
        </div>
      </div>

      <div class="w-full overflow-x-auto pb-8 hide-scrollbar cursor-crosshair">
        <div class="min-w-[800px] flex gap-[5px] mx-auto justify-center">
          {
            weeks.map((week) => (
              <div class="flex flex-col gap-[5px]">
                {week.map((day: any) => {
                  if (day.count === -1) {
                    // 空白占位符
                    return <div class="w-3.5 h-3.5 rounded-[3px] bg-transparent" />;
                  }
                  
                  const level = getLevel(day.count);
                  
                  return (
                    // 🌟 核心视觉渲染：随着等级提升，颜色加深，Hover 增加放大与霓虹光晕
                    <div
                      class:list={[
                        "w-3.5 h-3.5 rounded-[3px] transition-all duration-300 hover:scale-150 hover:z-10",
                        level === 0 && "bg-base-200/70 dark:bg-base-300/50 hover:bg-base-300",
                        level === 1 && "bg-primary/30 hover:bg-primary/40 hover:ring-2 hover:ring-primary/40",
                        level === 2 && "bg-primary/60 hover:bg-primary/70 hover:ring-2 hover:ring-primary/60",
                        level === 3 && "bg-primary hover:bg-primary hover:ring-2 hover:ring-primary hover:shadow-lg hover:shadow-primary/50",
                      ]}
                      title={day.count === 0 ? day.dateStr : `${day.dateStr} : 演算了 ${day.count} 篇数据`}
                    />
                  );
                })}
              </div>
            ))
          }
        </div>
      </div>

      <div class="flex justify-end items-center gap-2 mt-2 text-[10px] text-base-content/50 font-mono uppercase tracking-widest">
        <span>静默 (0)</span>
        <div class="flex gap-1.5 mx-2">
          <div class="w-3 h-3 rounded-[2px] bg-base-200/70 dark:bg-base-300/50"></div>
          <div class="w-3 h-3 rounded-[2px] bg-primary/30"></div>
          <div class="w-3 h-3 rounded-[2px] bg-primary/60"></div>
          <div class="w-3 h-3 rounded-[2px] bg-primary"></div>
        </div>
        <span>狂热 (3+)</span>
      </div>

    </div>

  </MainCard>
</BaseLayout>

<style>
  /* 隐藏丑陋的系统滚动条，保持赛博纯粹感 */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>