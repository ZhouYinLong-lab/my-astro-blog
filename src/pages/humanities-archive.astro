---
// 这是一个完全独立的 Astro 页面，摆脱了博客排版的干扰
import DossierArchive from '@/components/DossierArchive.jsx';

// 将问卷数组提取到顶部，完美解决 ts(2322) never[] 推断报错
const questionsList = [
  "最近一次你感到由衷的幸福/活着真好是在什么时候？",
  "你心里[最完美的一天]包含哪3个元素？",
  "到目前为止，你觉得自己做得最棒的一件事是什么？(哪怕在别人眼中微不足道)",
  "你最欣赏一个人身上的哪种特质？(不论身边人，还是公众人物)",
  "你最喜欢的一本书或一首诗里的一句话是什么？你为什么会记得这句话？",
  "当下的你，人生中最不能失去的一件东西是什么？",
  "你听说过[人生的推背感]这个词吗？你有这样的感受吗？",
  "浩瀚历史长河中，你最想与之促膝长谈的一个人是谁？",
  "有没有一件事(一个规则/一句话/一个人设)你曾经很确定，但现在想法变了？",
  "你觉得当下的自己，能为世界做的最微小、也最有意义的事是什么？",
  "附加问题1：如果能为10年后的世界留下一句话，你会说什么？",
  "附加问题2：如果可以，请你留下你感觉有意思的一句话（信手偶得的即可）"
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>人文十问</title>
  </head>
  <body class="bg-[#fcfaf2] min-h-screen relative overflow-x-hidden font-sans">
    
    {/* 背景层：文学相关小图标水印 (羽毛笔、书本、墨水瓶、怀表) */}
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden text-black/[0.03]">
      <!-- 羽毛笔 -->
      <svg class="absolute top-[10%] left-[5%] w-48 h-48 -rotate-12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
        <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
        <path d="M2 2l7.586 7.586"></path>
        <circle cx="11" cy="11" r="2"></circle>
      </svg>
      
      <!-- 书本 -->
      <svg class="absolute top-[20%] right-[5%] w-64 h-64 rotate-12" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path>
      </svg>

      <!-- 墨水瓶 -->
      <svg class="absolute bottom-[10%] left-[8%] w-56 h-56 -rotate-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 20V14a2 2 0 0 0-2-2h-8a2 2 0 0 0-2 2v6"></path>
        <path d="M8 2h8"></path>
        <path d="M10 2v4"></path>
        <path d="M14 2v4"></path>
        <path d="M6 22h12"></path>
        <line x1="12" y1="12" x2="12" y2="17"></line>
        <circle cx="12" cy="19" r="1"></circle>
      </svg>

      <!-- 怀表/时钟 -->
      <svg class="absolute bottom-[25%] right-[8%] w-40 h-40 rotate-[-15deg]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
        <line x1="12" y1="2" x2="12" y2="4"></line>
        <line x1="12" y1="20" x2="12" y2="22"></line>
        <line x1="2" y1="12" x2="4" y2="12"></line>
        <line x1="20" y1="12" x2="22" y2="12"></line>
      </svg>
    </div>

    {/* 内容层：左上角的返回按钮 + 你的 React 组件 */}
    <div class="relative z-10 max-w-6xl mx-auto p-4 md:p-8 pt-8">
      
      {/* 悬浮在顶部的返回博客按钮 */}
      <a 
        href="/blog/人文十问" 
        class="inline-flex items-center gap-2 mb-6 bg-white text-black font-bold px-4 py-2 border-4 border-black shadow-[4px_4px_0_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0_0_#000] active:shadow-none active:translate-x-[4px] active:translate-y-[4px] transition-all decoration-transparent"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 font-black" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        中止连接 (返回主站)
      </a>

      {/* 核心问卷组件：增加 as any 彻底绕过 TS 检查 */}
      <DossierArchive 
        client:only="react" 
        title="人文十问"
        archiveId="humanities_questions_v1" 
        questions={questionsList as any} 
      />
    </div>
  </body>
</html>