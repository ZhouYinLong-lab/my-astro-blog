---
import { Icon } from "astro-icon/components";
// 🌟 核心接入：引入 Frosti 主题内置的评论组件
// 注意：如果你的组件路径报错，请尝试换成 "@/components/widgets/Comment.astro"
import Comment from "@/components/Comment.astro";
import MainCard from "@/components/MainCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="后院 - 寒柳别苑">
  <MainCard title="别苑后院" description="公共涂鸦墙与通讯基站。">
    
    <div class="flex flex-col gap-12 mt-6">
      
      <section class="relative">
        <div class="flex items-center gap-3 mb-6">
          <Icon name="lucide:message-square-dashed" class="w-7 h-7 text-primary" />
          <h2 class="text-2xl font-bold tracking-wider">公共涂鸦墙</h2>
        </div>
        
        <p class="text-base-content/70 mb-6 pl-10 border-l-2 border-primary/30">
          欢迎来到后院。不论是技术探讨、灵感碰撞，还是单纯的赛博路过，都请在这里留下你的数字足迹。支持直接粘贴图片上传。
        </p>

        <div class="card bg-base-200/50 backdrop-blur-md border border-base-300 shadow-inner p-4 md:p-8 rounded-2xl min-h-[300px]">
          
          {/* 👇 魔法发生的地方：一键召唤评论区 👇 */}
          <Comment />

        </div>
      </section>

      <div class="divider before:bg-base-300/50 after:bg-base-300/50 text-base-content/30"><Icon name="lucide:radio" /></div>

      <section>
        <div class="flex items-center gap-3 mb-6">
          <Icon name="lucide:satellite-dish" class="w-7 h-7 text-primary" />
          <h2 class="text-2xl font-bold tracking-wider">直连通讯协议</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          
          <a href="mailto:Liuhanzhi23@outlook.com" target="_blank" rel="noopener noreferrer" class="card bg-base-100 border border-base-300 hover:border-primary hover:shadow-lg hover:-translate-y-1 transition-all duration-300 p-5 flex flex-row items-center gap-4 group cursor-pointer">
            <div class="p-3 bg-base-200 rounded-lg group-hover:bg-primary/10 group-hover:text-primary transition-colors">
              <Icon name="lucide:mail" class="w-6 h-6" />
            </div>
            <div>
              <div class="font-bold text-sm">Outlook 专线</div>
              <div class="text-xs text-base-content/60 font-mono mt-0.5">Liuhanzhi23@outlook.com</div>
            </div>
          </a>

          <a href="https://space.bilibili.com/511060666" target="_blank" rel="noopener noreferrer" class="card bg-base-100 border border-base-300 hover:border-[#fb7299] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 p-5 flex flex-row items-center gap-4 group cursor-pointer">
            <div class="p-3 bg-base-200 rounded-lg group-hover:bg-[#fb7299]/10 group-hover:text-[#fb7299] transition-colors">
              <Icon name="ri:bilibili-line" class="w-6 h-6" />
            </div>
            <div>
              <div class="font-bold text-sm">Bilibili 影像站</div>
              <div class="text-xs text-base-content/60 font-mono mt-0.5">UID: 511060666</div>
            </div>
          </a>

          <a href="https://github.com/ZhouYinLong-lab/" target="_blank" rel="noopener noreferrer" class="card bg-base-100 border border-base-300 hover:border-base-content hover:shadow-lg hover:-translate-y-1 transition-all duration-300 p-5 flex flex-row items-center gap-4 group cursor-pointer">
            <div class="p-3 bg-base-200 rounded-lg group-hover:bg-base-content/10 group-hover:text-base-content transition-colors">
              <Icon name="ri:github-line" class="w-6 h-6" />
            </div>
            <div>
              <div class="font-bold text-sm">GitHub 军火库</div>
              <div class="text-xs text-base-content/60 font-mono mt-0.5">ZhouYinLong-lab</div>
            </div>
          </a>

          <a href="/qq.jpg" target="_blank" rel="noopener noreferrer" class="card bg-base-100 border border-base-300 hover:border-[#12B7F5] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 p-5 flex flex-row items-center gap-4 group cursor-pointer">
            <div class="p-3 bg-base-200 rounded-lg group-hover:bg-[#12B7F5]/10 group-hover:text-[#12B7F5] transition-colors">
              <Icon name="ri:qq-line" class="w-6 h-6" />
            </div>
            <div>
              <div class="font-bold text-sm">QQ 好友</div>
              <div class="text-xs text-base-content/60 font-mono mt-0.5">扫码加QQ好友</div>
            </div>
          </a>

          <a href="/wechat.jpg" target="_blank" rel="noopener noreferrer" class="card bg-base-100 border border-base-300 hover:border-[#07C160] hover:shadow-lg hover:-translate-y-1 transition-all duration-300 p-5 flex flex-row items-center gap-4 group cursor-pointer">
            <div class="p-3 bg-base-200 rounded-lg group-hover:bg-[#07C160]/10 group-hover:text-[#07C160] transition-colors">
              <Icon name="ri:wechat-line" class="w-6 h-6" />
            </div>
            <div>
              <div class="font-bold text-sm">微信公众号</div>
              <div class="text-xs text-base-content/60 font-mono mt-0.5">订阅我的微信公众号“柳下语”</div>
            </div>
          </a>

        </div>
      </section>

    </div>
  </MainCard>
</BaseLayout>