---
import { Icon } from "astro-icon/components";
import CyberButton from "@/components/CyberButton.astro";
import MainCard from "@/components/MainCard.astro";
import FeatureCard from "@/components/mdx/FeatureCard.astro";
import HomeLoader from "@/components/widgets/HomeLoader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Home">

  <HomeLoader slot="fullscreen" />

  <MainCard
    title="寒柳别苑,柳丝舞春,邀君共绘新梦"
    description="这里是柳含知的赛博后花园。南京大学智能科学专业学生,主攻 AI/RL、全栈开发与创意技术。Build in public, learn in public."
    textOverlay="HOME"
    infoIcon="lucide:info"
  >
    <div class="space-y-8">
      <section class="py-6">
        <div class="flex flex-col items-center text-center">
          <h1
            class="text-4xl font-bold mb-4 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent leading-loose"
          >
            🛸 寒柳别苑
          </h1>
          <p class="text-xl text-base-content/80 max-w-3xl mb-10">
            这里是柳含知的赛博后花园。我是南京大学智能科学专业的学生,主攻 AI/RL、全栈开发与创意技术。Build in public, learn in public.
          </p>
          <p class="flex flex-wrap items-center justify-center gap-2 text-base md:text-lg text-base-content/80 mb-6">
            <Icon name="lucide:mail" class="w-5 h-5 text-primary" />
            <span class="font-semibold">Email:</span>
            <a
              href="mailto:251880158@smail.nju.edu.cn"
              class="link link-primary font-medium break-all"
            >
              251880158@smail.nju.edu.cn
            </a>
          </p>
          <p class="flex flex-wrap items-center justify-center gap-2 text-base md:text-lg text-base-content/80 mb-10">
            <Icon name="ri:github-line" class="w-5 h-5 text-primary" />
            <span class="font-semibold">GitHub:</span>
            <a
              href="https://github.com/ZhouYinLong-lab"
              target="_blank"
              class="link link-primary font-medium"
            >
              ZhouYinLong-lab
            </a>
            <span class="text-base-content/50 text-sm ml-2">21 仓库 · 947 commits · 11 followers</span>
          </p>
          
          {/* 👇 核心修改区域：改为上下排列（flex-col），并加大间距防止动画遮挡 */}
          <div class="flex flex-col items-center gap-12 mt-2">
            
            {/* 放大 1.15 倍，使其成为视觉绝对重心，并给上下动画留出空间 */}
            <div class="transform scale-[1.15] z-10">
              <CyberButton href="/blog" />
            </div>

            {/* B站按钮保持原大小，补充了 rounded-full 使其更加圆润协调 */}
            <a href="https://space.bilibili.com/511060666" target="_blank" class="btn btn-outline rounded-full gap-2 px-6">
              <Icon name="simple-icons:bilibili" class="w-5 h-5" />
              <span>关注我的B站</span>
            </a>
            
          </div>
        </div>
      </section>

      <section class="py-6">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="ri:github-line" class="w-6 h-6 text-primary" />
          <span>开源工坊</span>
          <a href="https://github.com/ZhouYinLong-lab" target="_blank" class="text-sm font-normal text-base-content/50 hover:text-primary transition-colors ml-2">@ZhouYinLong-lab →</a>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {
            [
              { name: "Dog-Skills", desc: "116 个 Claude Code 技能库，覆盖开发/设计/写作/学习/商业/健康", stars: 6, lang: "Markdown", url: "https://github.com/ZhouYinLong-lab/Dog-Skills" },
              { name: "NanE", desc: "NJU 校园互助平台 — JS/Node.js/PostgreSQL/PWA 全栈应用", stars: 6, lang: "JavaScript", url: "https://github.com/ZhouYinLong-lab/NanE" },
              { name: "HuaiHai-h5-map", desc: "淮海战役互动 H5 地图 — React/TS/Tailwind/PWA", stars: 2, lang: "TypeScript", url: "https://github.com/ZhouYinLong-lab/HuaiHai-h5-map" },
              { name: "Dog-LittleTools", desc: "9 个 Bash CLI 开发效率工具", stars: 4, lang: "Shell", url: "https://github.com/ZhouYinLong-lab/Dog-LittleTools" },
              { name: "nannahelper/docs", desc: "面向初学者的编程教程文档 — MkDocs/CI/CD", stars: 4, lang: "Python", url: "https://github.com/ZhouYinLong-lab/nannahelper" },
              { name: "my-astro-blog", desc: "本博客源码 — Astro 5 + DaisyUI 静态生成", stars: 3, lang: "Astro", url: "https://github.com/ZhouYinLong-lab/my-astro-blog" },
            ].map((repo) => (
              <a href={repo.url} target="_blank" class="card bg-base-200 hover:bg-base-300 transition-all duration-300 group border border-base-300">
                <div class="card-body p-5">
                  <div class="flex items-center gap-2 mb-2">
                    <Icon name="ri:folder-3-line" class="w-4 h-4 text-primary" />
                    <h3 class="font-bold text-sm group-hover:text-primary transition-colors">{repo.name}</h3>
                  </div>
                  <p class="text-xs text-base-content/60 mb-3 line-clamp-2">{repo.desc}</p>
                  <div class="flex items-center gap-3 text-xs text-base-content/40 mt-auto">
                    <span class="flex items-center gap-1"><Icon name="ri:star-line" class="w-3 h-3" /> {repo.stars}</span>
                    <span>{repo.lang}</span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>

        <div class="mt-4 p-4 bg-base-200 rounded-xl border border-base-300">
          <div class="flex flex-wrap items-center gap-4 text-sm text-base-content/70">
            <span class="flex items-center gap-1"><Icon name="ri:git-repository-line" class="w-4 h-4 text-primary" /> 21 公开仓库</span>
            <span class="flex items-center gap-1"><Icon name="ri:star-line" class="w-4 h-4 text-primary" /> 50+ Stars</span>
            <span class="flex items-center gap-1"><Icon name="ri:git-commit-line" class="w-4 h-4 text-primary" /> 947 过去一年 Commits</span>
            <span class="flex items-center gap-1"><Icon name="ri:git-pull-request-line" class="w-4 h-4 text-primary" /> 14 合并 PR</span>
            <span class="text-base-content/50">贡献: Supabase · MUI · MCP · Apache HertzBeat</span>
          </div>
        </div>
      </section>

      <section class="py-6">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:compass" class="w-6 h-6 text-primary" />
          <span>内容罗盘</span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <FeatureCard
            title="见微知著"
            description="记录对社会现象的独立思考与深度剖析。用理性的视角解构复杂的现实,拒绝人云亦云的喧嚣。"
            icon="lucide:newspaper"
            color="oklch(0.6 0.2 240)"
            url="/blog/categories" 
          />

          <FeatureCard
            title="岁月留温"
            description="褪去极客的冰冷外壳,写下那些触动人心的柔软瞬间。关于热爱、关于生活,以及每一份真挚的情感。"
            icon="lucide:feather"
            color="oklch(0.7 0.2 30)"
            url="/blog/categories" 
          />

          <FeatureCard
            title="赛博工坊"
            description="从大庚剑阵的手势识别到 SmartAgent 的寻路算法,这里存放着我所有天马行空、不拘一格的数字实验与开源项目。"
            icon="lucide:flask-conical"
            color="oklch(0.6 0.2 160)"
            url="/blog/categories" 
          />

          <FeatureCard
            title="碎片档案馆"
            description="吹奏 EWI 时的呼吸起伏,沉浸在《阿基拉》与交界地里的时光,以及在南大校园里捕捉到的点滴趣事。"
            icon="lucide:camera"
            color="oklch(0.7 0.2 80)"
            url="/blog/categories" 
          />

          <FeatureCard
            title="异乡人诗抄"
            description="跨越语言的边界,翻译与品读阿蒂尔·兰波等诗人的杰作,在字里行间寻找自由与蓬勃的生机。"
            icon="lucide:wind"
            color="oklch(0.5 0.2 300)"
            url="/blog/categories" 
          />

          <FeatureCard
            title="步履不停"
            description="记录一次次微小的顿悟与迷茫。这里没有一蹴而就的神话,只有一个普通人一步一个脚印的踏实前行。"
            icon="lucide:milestone"
            color="oklch(0.6 0.2 200)"
            url="/blog/categories" 
          />
        </div>
      </section>
    </div>
  </MainCard>
</BaseLayout>
