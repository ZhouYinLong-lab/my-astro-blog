---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import FeatureCard from "@/components/mdx/FeatureCard.astro";
import HomeLoader from "@/components/widgets/HomeLoader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Home">

  <HomeLoader slot="fullscreen" />

  <MainCard
    title="寒柳别苑,柳丝舞春,邀君共绘新梦"
    description="这里是柳含知的赛博后花园。我是南京大学智能科学专业的大一学生,我喜欢捣鼓一些有意思的东西,如果你有有趣的点子或项目,欢迎联系我！"
    textOverlay="HOME"
    infoIcon="lucide:info"
  >
    <div class="space-y-8">
      <!-- Hero Section -->
      <section class="py-6">
        <div class="flex flex-col items-center text-center">
          <h1
            class="text-4xl font-bold mb-4 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent leading-loose"
          >
            🛸 寒柳别苑
          </h1>
          <p class="text-xl text-base-content/80 max-w-3xl mb-8">
            这里是柳含知的赛博后花园。我是南京大学智能科学专业的大一学生,我喜欢捣鼓一些有趣的东西,如果你有一些有趣的点子或项目,欢迎联系我！
          </p>
          <div class="flex flex-wrap gap-4 justify-center">
            <a href="/blog" class="btn btn-primary gap-2 btn-shine-effect">
              <Icon name="lucide:book-open" class="w-5 h-5" />
              <span>进入博客</span>
            </a>
            <a href="https://space.bilibili.com/511060666" target="_blank" class="btn btn-outline gap-2">
              <Icon name="simple-icons:bilibili" class="w-5 h-5" />
              <span>关注我的B站</span>
            </a>
          </div>
        </div>
      </section>

      <section class="py-6">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:compass" class="w-6 h-6 text-primary" />
          <span>内容罗盘</span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <FeatureCard
            title="见微知著"
            description="记录对社会现象的独立思考与深度剖析。用理性的视角解构复杂的现实,拒绝人云亦云的喧嚣。"
            icon="lucide:newspaper"
            color="oklch(0.6 0.2 240)"
            url="/blog/categories" 
          />

          <FeatureCard
            title="岁月留温"
            description="褪去极客的冰冷外壳,写下那些触动人心的柔软瞬间。关于热爱、关于生活,以及每一份真挚的情感。"
            icon="lucide:feather"
            color="oklch(0.7 0.2 30)"
            url="/blog/categories" 
          />

          <FeatureCard
            title="赛博工坊"
            description="从 NoneBot 机器人的调教到夜鹭心情识别器,这里存放着我所有天马行空、不拘一格的数字实验。"
            icon="lucide:flask-conical"
            color="oklch(0.6 0.2 160)"
            url="/blog/categories" 
          />

          <FeatureCard
            title="碎片档案馆"
            description="吹奏 EWI 时的呼吸起伏,沉浸在《阿基拉》与交界地里的时光,以及在南大校园里捕捉到的点滴趣事。"
            icon="lucide:camera"
            color="oklch(0.7 0.2 80)"
            url="/blog/categories" 
          />

          <FeatureCard
            title="异乡人诗抄"
            description="跨越语言的边界,翻译与品读阿蒂尔·兰波等诗人的杰作,在字里行间寻找自由与蓬勃的生机。"
            icon="lucide:wind"
            color="oklch(0.5 0.2 300)"
            url="/blog/categories" 
          />

          <FeatureCard
            title="步履不停"
            description="记录一次次微小的顿悟与迷茫。这里没有一蹴而就的神话,只有一个普通人一步一个脚印的踏实前行。"
            icon="lucide:milestone"
            color="oklch(0.6 0.2 200)"
            url="/blog/categories" 
          />
        </div>
      </section>
    </div>
  </MainCard>
</BaseLayout>
