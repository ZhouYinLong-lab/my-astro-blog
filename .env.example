# ============================================================
# SECURITY WARNING
# ============================================================
# DO NOT commit actual credentials to this file or any other file
# in the repository. Use this file as a template only.
#
# If you previously had hardcoded credentials in source control
# (e.g., Supabase keys in DossierArchive.jsx, or the "frosti"
# admin password), those credentials are COMPROMISED and must
# be ROTATED immediately.
# ============================================================

# Supabase (人文十问)
# Required for the DossierArchive component
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Admin password for DossierArchive god mode
# (Client-side check only - not truly secure. For production,
#  implement proper server-side authentication.)
PUBLIC_ADMIN_PASSWORD=change-this-to-a-secure-value

# 百度站长推送
BAIDU_PUSH_TOKEN=your-baidu-push-token

# GitHub Token (optional, used for build-time GitHub API calls)
# NOTE: No longer used in client-side code for security reasons.
# GitHub API calls are made unauthenticated from the browser.
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
